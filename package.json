{
  "name": "my-portfolio",
  "description": "My personal portfolio app",
  "engines": {
    "node": ">=15.0.0"
  },
  "private": true,
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "node --max-old-space-size=4096 node_modules/vite/bin/vite.js build -c adapters/vercel-edge/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "deploy": "vercel deploy",
    "dev": "vite --mode ssr --port 4201",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "preview": "qwik build preview && vite preview --open",
    "qwik-speak-extract": "qwik-speak-extract --supportedLangs=en-US,pl-PL --assetsPath=i18n",
    "start": "vite --open --mode ssr",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@builder.io/qwik": "1.17.2",
    "@builder.io/qwik-city": "~1.17.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.4",
    "@types/eslint": "9.6.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "8.46.4",
    "@typescript-eslint/parser": "8.46.4",
    "eslint": "9.39.1",
    "eslint-plugin-qwik": "^1.17.2",
    "globals": "^16.5.0",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "qwik-speak": "^0.23.2",
    "tailwindcss": "^4.1.4",
    "typescript": "5.9.3",
    "undici": "7.16.0",
    "vercel": "^48.10.2",
    "vite": "7.2.2",
    "vite-tsconfig-paths": "5.1.4"
  },
  "dependencies": {
    "@builder.io/qwik-react": "^0.5.7",
    "framer-motion": "^12.23.24",
    "luxon": "^3.7.2"
  }
}
